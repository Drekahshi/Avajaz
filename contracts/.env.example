# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Your MetaMask private key used to deploy the contract
# Export from MetaMask: Account Details > Export Private Key
# ⚠️  Use a dedicated deployment wallet, NOT your main wallet.
PRIVATE_KEY="your_private_key_mnemonic_or_hex_here"

# The address of the backend Node.js agent wallet (0x...)
AGENT_ADDRESS="0xYourAgentAddressHere"
